<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="kernwald">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import kernwald urdf file -->
    <xacro:include filename="$(find kernwald_description)/urdf/kernwald.xacro" />
</robot>
