<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <joint name="gripper_base_joint" type="fixed">
        <parent link="tool_link" />
        <child link="gripper_base_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <link name="gripper_base_link">
        <xacro:box_inertial mass="0.25" x="0.2" y="0.06" z="0.02" origin_xyz="0 0 0.01" />
        <visual>
            <geometry>
                <box size="0.2 0.06 0.02" />
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 0" />
            <material name="dark_green" />
        </visual>
    </link>

    <!-- Right finger -->
    <joint name="right_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="right_finger_link" />
        <origin xyz="0.07 0 0.02" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit effort="1000.0" velocity="1.0" lower="-0.06" upper="0.0" />
        <mimic joint="left_finger_joint" multiplier="-1.0" />
    </joint>

    <link name="right_finger_link">
        <xacro:box_inertial mass="0.08" x="0.02" y="0.06" z="0.08" origin_xyz="0 0 0.04" />
        <visual>
            <geometry>
                <box size="0.02 0.06 0.08" />
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.06 0.08" />
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Left finger -->
    <joint name="left_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="left_finger_link" />
        <origin xyz="-0.07 0 0.02" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit effort="1000.0" velocity="1.0" lower="0.0" upper="0.06" />
    </joint>

    <link name="left_finger_link">
        <xacro:box_inertial mass="0.08" x="0.02" y="0.06" z="0.08" origin_xyz="0 0 0.04" />
        <visual>
            <geometry>
                <box size="0.02 0.06 0.08" />
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.06 0.08" />
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
        </collision>
    </link>
</robot>
