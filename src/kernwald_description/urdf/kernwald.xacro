<?xml version="1.0"?>

<robot name="kernwald" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Includes -->
    <xacro:include filename="common_properties.xacro" />
    <xacro:include filename="kernwald.ros2_control.xacro" />

    <xacro:arg name="use_gazebo" default="false" />

    <xacro:include filename="gripper.xacro" />
    <xacro:kernwald_ros2_control use_gazebo="$(arg use_gazebo)" />

    <!-- Base -->
    <link name="base_footprint" />

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <link name="base_link">
        <xacro:box_inertial mass="5.0" x="0.4" y="0.4" z="0.1" origin_xyz="0 0 0.05" />
        <visual>
            <geometry>
                <box size="0.4 0.4 0.1" />
            </geometry>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.4 0.1" />
            </geometry>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 1 -->
    <joint name="joint_1" type="revolute">
        <parent link="base_link" />
        <child link="shoulder_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
    </joint>

    <link name="shoulder_link">
        <xacro:cylinder_inertial mass="2.0" radius="0.1" length="0.5" origin_xyz="0 0 0.25" />
        <visual>
            <geometry>
                <cylinder length="0.5" radius="0.1" />
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.5" radius="0.1" />
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 2 -->
    <joint name="joint_2" type="revolute">
        <parent link="shoulder_link" />
        <child link="arm_link" />
        <origin xyz="0 0 0.5" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
    </joint>

    <link name="arm_link">
        <xacro:cylinder_inertial mass="1.5" radius="0.05" length="0.6" origin_xyz="0 0 0.3" />
        <visual>
            <geometry>
                <cylinder length="0.6" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.3" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.6" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.3" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 3 -->
    <joint name="joint_3" type="revolute">
        <parent link="arm_link" />
        <child link="elbow_link" />
        <origin xyz="0 0 0.6" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
    </joint>

    <link name="elbow_link">
        <xacro:cylinder_inertial mass="0.5" radius="0.05" length="0.1" origin_xyz="0 0 0.05" />
        <visual>
            <geometry>
                <cylinder length="0.1" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.1" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 4 -->
    <joint name="joint_4" type="revolute">
        <parent link="elbow_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
    </joint>

    <link name="forearm_link">
        <xacro:cylinder_inertial mass="1.0" radius="0.05" length="0.5" origin_xyz="0 0 0.25" />
        <visual>
            <geometry>
                <cylinder length="0.5" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.5" radius="0.05" />
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 5 -->
    <joint name="joint_5" type="revolute">
        <parent link="forearm_link" />
        <child link="wrist_link" />
        <origin xyz="0 0 0.5" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <link name="wrist_link">
        <xacro:box_inertial mass="0.4" x="0.1" y="0.1" z="0.05" origin_xyz="0 0 0.025" />
        <visual>
            <geometry>
                <box size="0.1 0.1 0.05" />
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.05" />
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Joint 6 -->
    <joint name="joint_6" type="revolute">
        <parent link="wrist_link" />
        <child link="hand_link" />
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
    </joint>

    <link name="hand_link">
        <xacro:box_inertial mass="0.2" x="0.1" y="0.1" z="0.02" origin_xyz="0 0 0.01" />
        <visual>
            <geometry>
                <box size="0.1 0.1 0.02" />
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.02" />
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Hand tool -->
    <joint name="hand_tool_joint" type="fixed">
        <parent link="hand_link" />
        <child link="tool_link" />
        <origin xyz="0 0 0.02" rpy="0 0 0" />
    </joint>

    <link name="tool_link">
        <xacro:box_inertial mass="0.05" x="0.02" y="0.02" z="0.02" origin_xyz="0 0 0" />
    </link>

    <!-- Gazebo -->
    <gazebo>
        <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find kernwald_bringup)/config/ros2_controllers.yaml</parameters>
        </plugin>
    </gazebo>
</robot>
